APP_NAME=Autonomous API Builder
APP_ENV=development
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/autonomous_api_builder
QUEUE_BACKEND=celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=
PLANNER_MODEL=gpt-4o-mini
PLANNER_API_KEY=
PLANNER_BASE_URL=https://api.openai.com/v1
PLANNER_MAX_RETRIES=2
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
STORAGE_BACKEND=local
STORAGE_LOCAL_BASE_PATH=./data/artifacts
OTEL_ENABLED=false
OTEL_SERVICE_NAME=autonomous-api-builder-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
